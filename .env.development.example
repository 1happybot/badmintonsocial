# TopMinton development environment template
# Copy to .env.development and adjust values for your local machine.

PORT=3000
NODE_ENV=development
DATABASE_URL=postgres://badmin:badmin_pwd@localhost:5432/topminton
SESSION_SECRET=replace-with-a-long-random-development-secret

# Optional: bootstrap admin (used if admins table is empty)
ADMIN_EMAIL=admin@topminton.se
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Platform Admin
