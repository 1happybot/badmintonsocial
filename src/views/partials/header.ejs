<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title %> · TopMinton</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css" />
  <script>
    // Prevent flash of wrong theme on page load
    (function() {
      const THEME_STORAGE_KEY = 'topminton-theme';
      const stored = localStorage.getItem(THEME_STORAGE_KEY);
      if (stored) {
        document.documentElement.setAttribute('data-bs-theme', stored);
      }
    })();
  </script>
</head>
<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">
      <span class="brand-emoji">🏸</span> TopMinton
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
            aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
        <li class="nav-item"><a class="nav-link" href="/about"><i class="bi bi-info-circle"></i> About Us</a></li>
        <% if (currentAdmin) { %>
          <li class="nav-item"><a class="nav-link" href="/admin"><i class="bi bi-shield-check"></i> Admin</a></li>
          <li class="nav-item d-flex align-items-center text-secondary px-2 small">
            Admin:&nbsp;<strong><%= currentAdmin.name %></strong>
          </li>
          <li class="nav-item">
            <form method="post" action="/admin/logout" class="d-inline">
              <button class="btn btn-outline-secondary btn-sm" type="submit">
                <i class="bi bi-box-arrow-right"></i> Admin Logout
              </button>
            </form>
          </li>
        <% } %>
        <% if (currentUser) { %>
          <li class="nav-item"><a class="nav-link" href="/players"><i class="bi bi-people"></i> Players</a></li>
          <li class="nav-item"><a class="nav-link" href="/challenges"><i class="bi bi-trophy"></i> Challenges</a></li>
          <li class="nav-item"><a class="nav-link" href="/wall-of-shame"><i class="bi bi-exclamation-triangle"></i> Wall of Shame</a></li>
          <li class="nav-item"><a class="nav-link" href="/players/<%= currentUser.id %>"><i class="bi bi-person-circle"></i> Profile</a></li>
          <li class="nav-item"><a class="nav-link" href="/rules"><i class="bi bi-book"></i> Rules</a></li>
          <li class="nav-item"><button id="themeToggle" class="btn btn-outline-secondary btn-sm theme-toggle-btn" title="Toggle theme"><i class="bi bi-moon"></i></button></li>
          <li class="nav-item d-flex align-items-center text-secondary px-2 small">
            Hi,&nbsp;<strong><%= currentUser.name %></strong>
          </li>
          <li class="nav-item">
            <form method="post" action="/logout" class="d-inline">
              <button class="btn btn-outline-secondary btn-sm" type="submit">
                <i class="bi bi-box-arrow-right"></i> Log out
              </button>
            </form>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/rules"><i class="bi bi-book"></i> Rules</a></li>
          <% if (!currentAdmin) { %>
            <li class="nav-item"><a class="nav-link" href="/admin/login"><i class="bi bi-shield-lock"></i> Admin</a></li>
          <% } %>
          <li class="nav-item"><button id="themeToggle" class="btn btn-outline-secondary btn-sm theme-toggle-btn" title="Toggle theme"><i class="bi bi-moon"></i></button></li>
          <li class="nav-item"><a class="nav-link" href="/login">Log in</a></li>
          <li class="nav-item"><a class="btn btn-primary btn-sm ms-lg-2" href="/register">Sign up</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<% if (flash) { %>
  <div class="container mt-3">
    <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show mb-0" role="alert">
      <i class="bi <%= flash.type === 'error' ? 'bi-exclamation-triangle' : 'bi-check-circle' %> me-2"></i>
      <%= flash.message %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  </div>
<% } %>

<main class="flex-grow-1 py-4">
  <div class="container">
