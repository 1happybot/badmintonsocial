<script>
  // Theme toggle functionality with persistence
  (function() {
    const htmlElement = document.documentElement;
    const themeToggle = document.getElementById('themeToggle');
    const THEME_STORAGE_KEY = 'topminton-theme';
    
    // Get initial theme from localStorage or default light theme
    function getInitialTheme() {
      const stored = localStorage.getItem(THEME_STORAGE_KEY);
      if (stored) return stored;
      return 'light';
    }
    
    // Set theme
    function setTheme(theme) {
      const isDark = theme === 'dark';
      htmlElement.setAttribute('data-bs-theme', theme);
      htmlElement.setAttribute('data-theme', isDark ? 'topmintondark' : 'topmintonlight');
      localStorage.setItem(THEME_STORAGE_KEY, theme);
      
      // Update icon
      if (themeToggle) {
        themeToggle.innerHTML = isDark ? '<i class="bi bi-sun"></i>' : '<i class="bi bi-moon"></i>';
      }
    }
    
    // Initialize theme on page load
    const initialTheme = getInitialTheme();
    setTheme(initialTheme);
    
    // Toggle theme on button click
    if (themeToggle) {
      themeToggle.addEventListener('click', function(e) {
        e.preventDefault();
        const currentTheme = htmlElement.getAttribute('data-bs-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        setTheme(newTheme);
      });
    }
  })();
</script>

