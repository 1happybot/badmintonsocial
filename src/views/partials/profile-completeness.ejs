<%
  // Calculate profile completeness
  const checks = {
    email: currentUser?.email ? 10 : 0,
    phone: currentUser?.phone_verified_at ? 15 : 0,
    avatar: currentUser?.avatar_style ? 10 : 0,
    bio: currentUser?.bio ? 10 : 0,
    city: currentUser?.city ? 15 : 0,
    skillRating: currentUser?.skill_rating ? 15 : 0,
    preferences: (currentUser?.shuttle_preference && currentUser?.preferred_format) ? 15 : 0,
  };
  
  const completeness = Object.values(checks).reduce((a, b) => a + b, 0);
  const items = [
    { label: 'Email verified', value: checks.email, icon: 'envelope-check', color: '#4caf50' },
    { label: 'Phone verified', value: checks.phone, icon: 'telephone-fill', color: '#2196F3' },
    { label: 'Profile photo', value: checks.avatar, icon: 'image', color: '#ff9800' },
    { label: 'Bio written', value: checks.bio, icon: 'file-text', color: '#9c27b0' },
    { label: 'City set', value: checks.city, icon: 'geo-alt-fill', color: '#00bcd4' },
    { label: 'Skill rating set', value: checks.skillRating, icon: 'graph-up', color: '#8bc34a' },
    { label: 'Preferences set', value: checks.preferences, icon: 'sliders', color: '#f44336' },
  ];
  
  const completedItems = items.filter(i => i.value > 0).length;
  const totalItems = items.length;
%>

<div class="profile-completeness card tile mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <h5 class="card-title mb-1">
          <i class="bi bi-star"></i> Profile Completeness
        </h5>
        <p class="card-text small text-secondary mb-0">
          <%= completeness %>% complete • <%= completedItems %>/<%= totalItems %> items
        </p>
      </div>
      <% if (completeness < 100) { %>
        <a href="/players/<%= currentUser.id %>/edit" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-pencil"></i> Complete
        </a>
      <% } else { %>
        <span class="badge text-bg-success">
          <i class="bi bi-check-circle"></i> Complete
        </span>
      <% } %>
    </div>

    <!-- Progress Bar -->
    <div class="progress mb-3" role="progressbar" style="height: 6px;">
      <div class="progress-bar bg-success" style="width: <%= completeness %>%;"></div>
    </div>

    <!-- Checklist -->
    <div class="row g-2 small">
      <% items.forEach(item => { %>
        <div class="col-6">
          <div class="d-flex align-items-center gap-2 p-2 rounded" style="background: <%= item.value > 0 ? '#f0f0f0' : 'transparent' %>;">
            <% if (item.value > 0) { %>
              <i class="bi bi-<%= item.icon %>" style="color: <%= item.color %>; font-size: 1.2rem;"></i>
              <div class="text-secondary"><strike><%= item.label %></strike></div>
            <% } else { %>
              <i class="bi bi-circle" style="color: #ccc;"></i>
              <div class="text-secondary"><%= item.label %></div>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>

    <% if (completeness === 100) { %>
      <div class="alert alert-success mt-3 mb-0 small">
        <i class="bi bi-star-fill"></i> Your profile is complete! You're ready to play.
      </div>
    <% } else if (completeness >= 75) { %>
      <div class="alert alert-info mt-3 mb-0 small">
        <i class="bi bi-info-circle"></i> Almost there! Complete a few more items to unlock rewards.
      </div>
    <% } %>
  </div>
</div>
