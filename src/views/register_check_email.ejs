<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card tile">
      <div class="card-body p-4 p-md-5 text-center">
        <div class="mb-3">
          <i class="bi bi-envelope-check text-primary" style="font-size: 2.5rem;"></i>
        </div>
        <h1 class="h3 mb-2">Check your email</h1>
        <p class="text-secondary mb-4">
          We sent a confirmation link to <strong><%= maskedEmail %></strong>.
          Click the link in that email to confirm your account.
        </p>

        <form method="post" action="/register/check-email/resend" class="mb-3">
          <button type="submit" class="btn btn-outline-primary w-100">
            <i class="bi bi-arrow-repeat"></i> Resend confirmation email
          </button>
        </form>

        <p class="text-secondary small mb-0">
          Wrong email? <a href="/register">Start signup again</a>.
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
