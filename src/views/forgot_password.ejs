<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card tile">
      <div class="card-body p-4 p-md-5">
        <h1 class="h3 text-center mb-1"><i class="bi bi-key text-primary"></i> Forgot password</h1>
        <p class="text-secondary text-center mb-4">Enter your email and we'll send you a reset link.</p>

        <% if (typeof successMessage === 'string' && successMessage) { %>
          <div class="alert alert-success"><i class="bi bi-check-circle"></i> <%= successMessage %></div>
        <% } %>
        <% if (typeof errorMessage === 'string' && errorMessage) { %>
          <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= errorMessage %></div>
        <% } %>

        <% if (!successMessage) { %>
          <form method="post" action="/forgot-password">
            <div class="mb-4">
              <label class="form-label">Email address</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                <input type="email" name="email" class="form-control" required maxlength="200"
                       value="<%= (form && form.email) || '' %>" autofocus>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-lg w-100">
              <i class="bi bi-send"></i> Send reset link
            </button>
          </form>
        <% } %>

        <p class="text-center text-secondary small mt-4 mb-0">
          Remembered it? <a href="/login">Log in</a>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
