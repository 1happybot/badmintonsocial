<%- include('partials/header') %>

<%
  const statusColor = { pending: 'warning', accepted: 'info', completed: 'success', declined: 'danger', cancelled: 'secondary' };
  function fmtDate(d) { return new Date(d).toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' }); }
%>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
  <div>
    <h1 class="mb-1"><i class="bi bi-trophy"></i> Challenges</h1>
    <p class="text-secondary mb-0">Manage your matches and record results</p>
  </div>
  <a class="btn btn-primary" href="/players"><i class="bi bi-plus-lg"></i> Find an opponent</a>
</div>

<div class="card tile mb-4">
  <div class="card-body py-3">
    <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between">
      <div class="small text-secondary">
        <i class="bi bi-shield-exclamation"></i> Automated fair-play checks are active
      </div>
      <div class="d-flex flex-wrap gap-2 small">
        <span class="badge text-bg-secondary">Pending outgoing: <%= policyCounters.pendingOutgoing %>/8</span>
        <span class="badge text-bg-secondary">Sent last hour: <%= policyCounters.createdLastHour %>/10</span>
        <span class="badge text-bg-<%= policyCounters.cancellations30d >= 4 ? 'danger' : 'secondary' %>">Cancellations (30d): <%= policyCounters.cancellations30d %>/6</span>
      </div>
    </div>
  </div>
</div>

<div class="card tile mb-4">
  <div class="card-body">
    <h2 class="h5 mb-3"><i class="bi bi-calendar-plus"></i> Host a match</h2>
    <form method="post" action="/hosted-matches">
      <div class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label small text-secondary mb-1">Title</label>
          <input type="text" name="title" class="form-control" maxlength="120" placeholder="Saturday Doubles" required>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-secondary mb-1">When</label>
          <input type="datetime-local" name="scheduled_at" class="form-control" required>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-secondary mb-1">Location</label>
          <input type="text" name="location" class="form-control" maxlength="160" placeholder="Court / venue" required>
        </div>
        <div class="col-md-1">
          <label class="form-label small text-secondary mb-1">Max</label>
          <input type="number" name="max_players" class="form-control" value="4" min="2" max="12" required>
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-circle"></i> Host</button>
        </div>
      </div>
      <div class="mt-2">
        <label class="form-label small text-secondary mb-1">Message (optional)</label>
        <input type="text" name="message" class="form-control" maxlength="400" placeholder="Bring shuttles, all levels welcome.">
      </div>
    </form>
  </div>
</div>

<div class="d-flex align-items-center mb-3">
  <h2 class="h5 mb-0"><i class="bi bi-people-fill text-primary"></i> Hosted matches</h2>
  <span class="badge text-bg-secondary ms-2"><%= hostedOpen.length %></span>
</div>
<% if (hostedOpen.length === 0) { %>
  <div class="card tile mb-4"><div class="card-body text-center text-secondary py-4">
    No hosted matches yet.
  </div></div>
<% } else { %>
  <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
    <% hostedOpen.forEach(function(m){
         const isHost = currentUser && currentUser.id === m.host_id;
         const isFull = m.joined_count >= m.max_players || m.status === 'full';
    %>
      <div class="col">
        <div class="card tile h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h3 class="h6 mb-0"><a href="/hosted-matches/<%= m.id %>" class="text-decoration-none"><%= m.title %></a></h3>
              <span class="badge text-bg-<%= m.status === 'open' ? 'success' : m.status === 'full' ? 'warning' : 'secondary' %>"><%= m.status %></span>
            </div>
            <div class="small text-secondary mb-3">
              <div><i class="bi bi-person"></i> Host: <%= m.host_name %></div>
              <div><i class="bi bi-calendar-event"></i> <%= fmtDate(m.scheduled_at) %></div>
              <div><i class="bi bi-geo-alt"></i> <%= m.location %></div>
              <div><i class="bi bi-people"></i> <%= m.joined_count %>/<%= m.max_players %> players</div>
            </div>
            <% if (m.message) { %>
              <p class="small mb-3 fst-italic text-body">“<%= m.message %>”</p>
            <% } %>

            <% if (isHost) { %>
              <form method="post" action="/hosted-matches/<%= m.id %>/cancel" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-x-circle"></i> Cancel hosted match</button>
              </form>
            <% } else if (m.am_joined) { %>
              <form method="post" action="/hosted-matches/<%= m.id %>/leave" class="d-inline">
                <button type="submit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-box-arrow-left"></i> Leave</button>
              </form>
            <% } else { %>
              <form method="post" action="/hosted-matches/<%= m.id %>/join" class="d-inline">
                <button type="submit" class="btn btn-primary btn-sm" <%= isFull ? 'disabled' : '' %>>
                  <i class="bi bi-box-arrow-in-right"></i> <%= isFull ? 'Full' : 'Join' %>
                </button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<div class="row g-4 mb-4">
  <!-- Incoming column -->
  <div class="col-lg-6">
    <div class="d-flex align-items-center mb-3">
      <h2 class="h5 mb-0"><i class="bi bi-inbox-fill text-warning"></i> Incoming</h2>
      <span class="badge text-bg-secondary ms-2"><%= incoming.length %></span>
    </div>
    <% if (incoming.length === 0) { %>
      <div class="card tile"><div class="card-body text-center text-secondary py-4">
        <i class="bi bi-check2-circle fs-1 opacity-50 d-block mb-2"></i>
        No pending challenges.
      </div></div>
    <% } %>
    <% incoming.forEach(function(c){ %>
      <div class="card tile mb-3">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <h3 class="h6 mb-0"><i class="bi bi-person-circle"></i> From <%= c.challenger_name %></h3>
            <span class="badge text-bg-warning">pending</span>
          </div>
          <div class="small text-secondary mb-2">
            <div><i class="bi bi-calendar-event"></i> <%= fmtDate(c.proposed_at) %></div>
            <div><i class="bi bi-geo-alt"></i> <%= c.location %></div>
          </div>
          <% if (c.message) { %>
            <p class="small mb-3 fst-italic text-body">“<%= c.message %>”</p>
          <% } %>
          <div class="d-flex gap-2">
            <form method="post" action="/challenges/<%= c.id %>/accept" class="d-inline flex-grow-1">
              <button class="btn btn-success w-100" type="submit"><i class="bi bi-check-lg"></i> Accept</button>
            </form>
            <form method="post" action="/challenges/<%= c.id %>/decline" class="d-inline flex-grow-1">
              <button class="btn btn-outline-danger w-100" type="submit"><i class="bi bi-x-lg"></i> Decline</button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Outgoing column -->
  <div class="col-lg-6">
    <div class="d-flex align-items-center mb-3">
      <h2 class="h5 mb-0"><i class="bi bi-send-fill text-info"></i> Outgoing</h2>
      <span class="badge text-bg-secondary ms-2"><%= outgoing.length %></span>
    </div>
    <% if (outgoing.length === 0) { %>
      <div class="card tile"><div class="card-body text-center text-secondary py-4">
        <i class="bi bi-send fs-1 opacity-50 d-block mb-2"></i>
        No outgoing challenges.
      </div></div>
    <% } %>
    <% outgoing.forEach(function(c){ %>
      <div class="card tile mb-3">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <h3 class="h6 mb-0"><i class="bi bi-person-circle"></i> To <%= c.opponent_name %></h3>
            <span class="badge text-bg-warning">awaiting</span>
          </div>
          <div class="small text-secondary mb-2">
            <div><i class="bi bi-calendar-event"></i> <%= fmtDate(c.proposed_at) %></div>
            <div><i class="bi bi-geo-alt"></i> <%= c.location %></div>
          </div>
          <% if (c.message) { %>
            <p class="small mb-3 fst-italic text-body">“<%= c.message %>”</p>
          <% } %>
          <form method="post" action="/challenges/<%= c.id %>/cancel" class="d-inline">
            <button class="btn btn-outline-secondary btn-sm" type="submit"><i class="bi bi-x-circle"></i> Cancel</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<!-- Upcoming matches -->
<div class="d-flex align-items-center mb-3">
  <h2 class="h5 mb-0"><i class="bi bi-calendar-check-fill text-success"></i> Upcoming matches</h2>
  <span class="badge text-bg-secondary ms-2"><%= upcoming.length %></span>
</div>
<% if (upcoming.length === 0) { %>
  <div class="card tile mb-4"><div class="card-body text-center text-secondary py-4">
    <i class="bi bi-calendar fs-1 opacity-50 d-block mb-2"></i>
    No matches scheduled.
  </div></div>
<% } else { %>
  <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
    <% upcoming.forEach(function(c){ %>
      <div class="col">
        <div class="card tile h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h3 class="h6 mb-0"><%= c.challenger_name %> <span class="text-secondary">vs</span> <%= c.opponent_name %></h3>
              <span class="badge text-bg-info">scheduled</span>
            </div>
            <div class="small text-secondary mb-3">
              <div><i class="bi bi-calendar-event"></i> <%= fmtDate(c.proposed_at) %></div>
              <div><i class="bi bi-geo-alt"></i> <%= c.location %></div>
            </div>

            <form method="post" action="/challenges/<%= c.id %>/result">
              <div class="row g-2 align-items-end">
                <div class="col-sm-5">
                  <label class="form-label small text-secondary mb-1">Winner</label>
                  <select name="winner_id" class="form-select form-select-sm" required>
                    <option value="<%= c.challenger_id %>"><%= c.challenger_name %></option>
                    <option value="<%= c.opponent_id %>"><%= c.opponent_name %></option>
                  </select>
                </div>
                <div class="col-sm-4">
                  <label class="form-label small text-secondary mb-1">Score</label>
                  <input type="text" name="score" class="form-control form-control-sm" placeholder="21-18, 21-15" maxlength="40">
                </div>
                <div class="col-sm-3">
                  <button class="btn btn-primary btn-sm w-100" type="submit">
                    <i class="bi bi-flag"></i> Record
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<!-- History -->
<div class="d-flex align-items-center mb-3">
  <h2 class="h5 mb-0"><i class="bi bi-clock-history"></i> History</h2>
  <span class="badge text-bg-secondary ms-2"><%= history.length %></span>
</div>
<% if (history.length === 0) { %>
  <div class="card tile"><div class="card-body text-center text-secondary py-4">
    No past matches yet.
  </div></div>
<% } else { %>
  <div class="list-group">
    <% history.forEach(function(c){ %>
      <% const feedbackKey = `${c.id}:${c.counterpart_id}`; %>
      <div class="list-group-item bg-body-tertiary border">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
          <div>
            <strong><%= c.challenger_name %></strong>
            <span class="text-secondary">vs</span>
            <strong><%= c.opponent_name %></strong>
            <span class="badge text-bg-<%= statusColor[c.status] || 'secondary' %> ms-2"><%= c.status %></span>
            <div class="small text-secondary mt-1">
              <i class="bi bi-calendar-event"></i> <%= fmtDate(c.proposed_at) %>
              <span class="mx-1">·</span>
              <i class="bi bi-geo-alt"></i> <%= c.location %>
            </div>
          </div>
          <% if (c.status === 'completed') { %>
            <div class="text-end small">
              <div><i class="bi bi-trophy-fill text-warning"></i> <strong><%= c.winner_name %></strong></div>
              <% if (c.score) { %><div class="text-secondary"><%= c.score %></div><% } %>
            </div>
          <% } %>
        </div>

        <% if ((c.status === 'completed' || c.status === 'cancelled') && !feedbackGivenKeys.includes(feedbackKey)) { %>
          <form method="post" action="/challenges/<%= c.id %>/feedback" class="mt-3 border-top pt-3">
            <input type="hidden" name="to_user_id" value="<%= c.counterpart_id %>">
            <div class="row g-2 align-items-end">
              <div class="col-md-2">
                <label class="form-label small text-secondary mb-1">Rating</label>
                <input type="number" class="form-control form-control-sm" name="rating" min="1" max="10" required>
              </div>
              <div class="col-md-6">
                <label class="form-label small text-secondary mb-1">Comment (optional)</label>
                <input type="text" class="form-control form-control-sm" name="comment" maxlength="220" placeholder="Match experience, communication, fairness...">
              </div>
              <div class="col-md-4 d-flex gap-2 align-items-center">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="reported_no_show" id="noShow-<%= c.id %>">
                  <label class="form-check-label small" for="noShow-<%= c.id %>">No-show</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="reported_non_payment" id="nonPayment-<%= c.id %>">
                  <label class="form-check-label small" for="nonPayment-<%= c.id %>">Did not pay host</label>
                </div>
                <button class="btn btn-sm btn-outline-primary ms-auto" type="submit">Submit feedback</button>
              </div>
            </div>
          </form>
        <% } else if (feedbackGivenKeys.includes(feedbackKey)) { %>
          <div class="mt-2 small text-success"><i class="bi bi-check-circle"></i> Feedback already submitted for this match.</div>
        <% } %>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
