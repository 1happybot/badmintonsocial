<%- include('../partials/header') %>

<div id="onboarding-welcome" class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <!-- Welcome Hero -->
      <div class="text-center mb-5">
        <div class="display-6 mb-3">
          <i class="bi bi-trophy" style="color: #ff6b35;"></i>
        </div>
        <h1 class="mb-3">Welcome to TopMinton, <%= userName %>!</h1>
        <p class="lead text-secondary mb-4">
          Let's get you set up to find badminton players and join matches in your area.
        </p>
      </div>

      <!-- Onboarding Steps Preview -->
      <div class="card tile mb-4 bg-base-200">
        <div class="card-body">
          <h5 class="card-title mb-3"><i class="bi bi-list-check"></i> What's Next</h5>
          <div class="d-flex flex-column gap-2 small">
            <div class="d-flex align-items-center gap-2">
              <span class="badge badge-primary">1</span>
              <div>
                <strong>Verify Phone</strong>
                <div class="text-secondary">Enable SMS challenges and event joins</div>
              </div>
            </div>
            <div class="d-flex align-items-center gap-2">
              <span class="badge badge-outline">2</span>
              <div>
                <strong>Your First Event</strong>
                <div class="text-secondary">Join or host your first match</div>
              </div>
            </div>
            <div class="d-flex align-items-center gap-2">
              <span class="badge badge-outline">3</span>
              <div>
                <strong>Start Playing</strong>
                <div class="text-secondary">Find opponents and level up</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Platform Features -->
      <div class="row g-2 mb-4">
        <div class="col-6">
          <div class="card tile text-center">
            <div class="card-body p-3">
              <div class="h4 mb-2"><i class="bi bi-people" style="color: #4ecdc4;"></i></div>
              <div class="small"><strong>Find Players</strong><br>Match with your skill level</div>
            </div>
          </div>
        </div>
        <div class="col-6">
          <div class="card tile text-center">
            <div class="card-body p-3">
              <div class="h4 mb-2"><i class="bi bi-calendar-plus" style="color: #95e1d3;"></i></div>
              <div class="small"><strong>Host Events</strong><br>Organize matches easily</div>
            </div>
          </div>
        </div>
        <div class="col-6">
          <div class="card tile text-center">
            <div class="card-body p-3">
              <div class="h4 mb-2"><i class="bi bi-award" style="color: #f38181;"></i></div>
              <div class="small"><strong>Earn Rewards</strong><br>Build your reputation</div>
            </div>
          </div>
        </div>
        <div class="col-6">
          <div class="card tile text-center">
            <div class="card-body p-3">
              <div class="h4 mb-2"><i class="bi bi-graph-up" style="color: #aa96da;"></i></div>
              <div class="small"><strong>Level Up</strong><br>Track your progress</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Referral Code Card -->
      <div class="card tile mb-4">
        <div class="card-body">
          <h5 class="card-title mb-3"><i class="bi bi-share-fill"></i> Share Your Referral Code</h5>
          <p class="small text-secondary mb-3">
            Earn <strong>50 TopMinton points</strong> for every friend you refer! Share your unique code:
          </p>
          <div class="input-group mb-2">
            <input 
              type="text" 
              class="form-control" 
              id="referral-code-display"
              value="<%= currentUser.referral_code %>"
              readonly
              style="font-weight: bold; letter-spacing: 1px; font-size: 1.1rem;"
            >
            <button class="btn btn-outline-primary" type="button" id="copy-referral-btn">
              <i class="bi bi-clipboard"></i> Copy
            </button>
          </div>
          <p class="small text-secondary mb-0">
            <i class="bi bi-info-circle"></i> Your friends can enter this code during onboarding to get +100 bonus points!
          </p>
        </div>
      </div>
      <div class="card tile mb-4" style="border: 2px solid #ddd;">
        <div class="card-body">
          <h5 class="card-title mb-3"><i class="bi bi-graph-up"></i> Your Skill Level</h5>
          <p class="text-secondary small mb-3">Current rating: <strong><%= skillRating %>/10</strong></p>
          <div class="skill-scale d-flex align-items-end gap-1 mb-3" style="height: 60px;">
            <% for (let i = 1; i <= 10; i++) { %>
              <div class="flex-grow-1 bg-light border rounded" 
                   style="height: <%= i * 10 %>%; background: <%= i <= skillRating ? '#ff6b35' : '#eee' %>; cursor: pointer; transition: all 0.2s;"
                   onmouseover="this.style.opacity='0.8'"
                   onmouseout="this.style.opacity='1'"
                   title="Level <%= i %>">
              </div>
            <% } %>
          </div>
          <div class="text-secondary small">
            <div><strong class="text-warning">1-3:</strong> Beginner (< 1 year)</div>
            <div><strong class="text-info">4-5:</strong> Casual (1-2 years)</div>
            <div><strong class="text-success">6-7:</strong> Intermediate (Club level)</div>
            <div><strong class="text-danger">8-9:</strong> Advanced (B-rank)</div>
            <div><strong>10:</strong> Expert (A-rank tournaments)</div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="d-flex gap-2">
        <button class="btn btn-primary flex-grow-1" id="continue-btn">
          Continue <i class="bi bi-arrow-right"></i>
        </button>
        <button class="btn btn-ghost flex-grow-1" id="skip-btn">
          Skip for now
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@popper/core@2"></script>
<script src="https://cdn.jsdelivr.net/npm/shepherd.js@13/dist/shepherd.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/shepherd.js@13/dist/shepherd.css">
<style>
  .shepherd-element {
    max-width: 400px;
  }
  .shepherd-element .shepherd-content {
    background: white;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    border: none;
  }
  .shepherd-element .shepherd-header {
    font-weight: 600;
    color: #ff6b35;
    padding: 1.5rem 1.5rem 1rem;
  }
  .shepherd-element .shepherd-text {
    padding: 0 1.5rem 1rem;
    color: #555;
    line-height: 1.6;
  }
  .shepherd-element .shepherd-footer {
    padding: 1rem 1.5rem;
    background: #fafafa;
    border-top: 1px solid #eee;
    border-radius: 0 0 12px 12px;
  }
  .shepherd-button {
    background: #ff6b35;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0.6rem 1.2rem;
    font-weight: 500;
    cursor: pointer;
  }
  .shepherd-button:hover {
    background: #e55a23;
  }
  .shepherd-button.shepherd-cancel-icon {
    background: white;
    color: #999;
  }
</style>

<script>
document.getElementById('continue-btn').addEventListener('click', async () => {
  try {
    const response = await fetch('/onboarding/welcome', { 
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
    });
    if (response.ok) {
      window.location.href = '/onboarding/phone';
    } else {
      alert('Something went wrong. Please try again.');
    }
  } catch (err) {
    console.error('Error:', err);
    alert('Failed to continue onboarding.');
  }
});

document.getElementById('skip-btn').addEventListener('click', async () => {
  if (!confirm('Skip setup? You can complete this later from your profile.')) return;
  try {
    const response = await fetch('/onboarding/skip', { method: 'POST' });
    const data = await response.json();
    if (data.success) {
      window.location.href = data.redirect;
    } else {
      alert('Something went wrong. Please try again.');
    }
  } catch (err) {
    console.error('Error:', err);
    alert('Failed to skip onboarding.');
  }
});

// Copy referral code
document.getElementById('copy-referral-btn')?.addEventListener('click', () => {
  const code = document.getElementById('referral-code-display').value;
  navigator.clipboard.writeText(code).then(() => {
    const btn = document.getElementById('copy-referral-btn');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="bi bi-check-lg"></i> Copied!';
    btn.classList.add('btn-success');
    btn.classList.remove('btn-outline-primary');
    setTimeout(() => {
      btn.innerHTML = originalText;
      btn.classList.remove('btn-success');
      btn.classList.add('btn-outline-primary');
    }, 2000);
  });
});
</script>

<%- include('../partials/footer') %>
