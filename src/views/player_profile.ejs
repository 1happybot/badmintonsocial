<%- include('partials/header') %>

<%
  const ratingColor = player.skill_rating >= 8 ? 'warning' : player.skill_rating >= 5 ? 'info' : 'success';
  const avatar = getAvatarEmoji(player.avatar_style);
  const statusColor = { pending: 'warning', accepted: 'info', completed: 'success', declined: 'danger', cancelled: 'secondary' };
%>

<div class="card tile mb-4">
  <div class="card-body">
    <div class="d-flex align-items-center flex-wrap gap-3">
      <div class="avatar avatar-lg <%= getAvatarClass(player.avatar_style) %>"><%= avatar %></div>
      <div class="flex-grow-1">
        <h1 class="h3 mb-1"><%= player.name %></h1>
        <div class="text-secondary small">
          <i class="bi bi-geo-alt"></i> <%= player.city || 'Unknown city' %>
          <span class="mx-2">·</span>
          <span class="badge text-bg-<%= ratingColor %>">Rating <%= player.skill_rating %>/10</span>
          <span class="mx-2">·</span>
          <span class="badge text-bg-secondary"><%= player.preferred_format %></span>
          <span class="mx-2">·</span>
          <span class="badge text-bg-info">Feedback <%= Number(player.avg_feedback_rating || 0).toFixed(1) %>/10</span>
        </div>
      </div>
      <% if (currentUser && currentUser.id !== player.id) { %>
        <a class="btn btn-primary" href="/challenges/new/<%= player.id %>">
          <i class="bi bi-send"></i> Challenge <%= player.name %>
        </a>
      <% } else if (currentUser && currentUser.id === player.id) { %>
        <a class="btn btn-outline-primary" href="/players/<%= player.id %>/edit">
          <i class="bi bi-pencil-square"></i> Edit profile
        </a>
      <% } %>
    </div>

    <% if (player.bio) { %>
      <p class="mt-3 mb-0 text-secondary"><%= player.bio %></p>
    <% } %>

    <div class="d-flex flex-wrap gap-2 mt-3">
      <span class="badge text-bg-dark"><i class="bi bi-hand-index-thumb"></i> <%= player.handedness %>-handed</span>
      <span class="badge text-bg-dark"><i class="bi bi-disc"></i> <%= player.shuttle_preference %> shuttle</span>
      <% if (player.interested_in_tournaments) { %>
        <span class="badge text-bg-success"><i class="bi bi-trophy"></i> Tournament-ready</span>
      <% } %>
      <% if (player.club_player) { %>
        <span class="badge text-bg-primary"><i class="bi bi-building"></i> Club player</span>
      <% } %>
      <% if (player.feedback_count > 0) { %>
        <span class="badge text-bg-secondary"><i class="bi bi-chat-heart"></i> <%= player.feedback_count %> feedback ratings</span>
      <% } %>
    </div>

    <% if (player.team_mode) { %>
      <div class="card tile mt-3">
        <div class="card-body py-3">
          <h3 class="h6 mb-2"><i class="bi bi-people-fill"></i> Doubles Team</h3>
          <div class="small text-secondary">
            Partner: <strong><%= player.partner_name || 'Not set' %></strong>
            <% if (player.partner_handedness) { %>
              <span class="mx-1">·</span><%= player.partner_handedness %>-handed
            <% } %>
            <% if (player.partner_skill_rating) { %>
              <span class="mx-1">·</span>Rating <%= player.partner_skill_rating %>/10
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>

<h2 class="h5 mb-3"><i class="bi bi-patch-check"></i> Badges</h2>
<% if (!badges || badges.length === 0) { %>
  <div class="card tile mb-4"><div class="card-body text-secondary">No badges earned yet.</div></div>
<% } else { %>
  <div class="row g-3 mb-4">
    <% badges.forEach(function(b){ %>
      <div class="col-sm-6 col-lg-4">
        <div class="card tile h-100">
          <div class="card-body">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge text-bg-warning"><i class="bi <%= getBadgeIcon(b.slug, b.name) %>"></i></span>
              <strong><%= b.name %></strong>
            </div>
            <% if (b.description) { %>
              <p class="text-secondary small mb-2"><%= b.description %></p>
            <% } %>
            <div class="small text-secondary">Awarded <%= new Date(b.awarded_at).toLocaleDateString() %></div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<% if (currentUser && currentUser.id === player.id) { %>
  <h2 class="h5 mb-3"><i class="bi bi-send-check"></i> Apply For Badge</h2>
  <% if (!availableBadges || availableBadges.length === 0) { %>
    <div class="card tile mb-4"><div class="card-body text-secondary">No additional active badges available to apply for.</div></div>
  <% } else { %>
    <div class="row g-3 mb-4">
      <% availableBadges.forEach(function(b){
           const pending = (badgeApplications || []).find(function(a){
             return a.badge_id === b.id && a.status === 'pending';
           });
      %>
        <div class="col-md-6">
          <div class="card tile h-100">
            <div class="card-body">
              <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge text-bg-info"><i class="bi <%= getBadgeIcon(b.slug, b.name) %>"></i></span>
                <strong><%= b.name %></strong>
              </div>
              <% if (b.description) { %>
                <p class="text-secondary small mb-3"><%= b.description %></p>
              <% } %>
              <% if (pending) { %>
                <span class="badge text-bg-warning">Application pending</span>
              <% } else { %>
                <form method="post" action="/players/<%= player.id %>/badges/apply" class="d-grid gap-2">
                  <input type="hidden" name="badge_id" value="<%= b.id %>">
                  <textarea
                    name="note"
                    class="form-control form-control-sm"
                    rows="2"
                    maxlength="220"
                    placeholder="Optional note to admins (why you should receive this badge)"></textarea>
                  <button class="btn btn-sm btn-primary" type="submit">
                    <i class="bi bi-send"></i> Apply
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <h3 class="h6 mb-2">My Badge Applications</h3>
  <% if (!badgeApplications || badgeApplications.length === 0) { %>
    <div class="card tile mb-4"><div class="card-body text-secondary">No badge applications submitted yet.</div></div>
  <% } else { %>
    <div class="table-responsive mb-4">
      <table class="table table-sm align-middle">
        <thead>
          <tr>
            <th>Badge</th>
            <th>Status</th>
            <th>Submitted</th>
          </tr>
        </thead>
        <tbody>
          <% badgeApplications.forEach(function(a){ %>
            <tr>
              <td>
                <strong><i class="bi <%= getBadgeIcon(a.slug, a.name) %> me-1"></i><%= a.name %></strong>
                <% if (a.note) { %>
                  <div class="small text-secondary"><%= a.note %></div>
                <% } %>
              </td>
              <td>
                <span class="badge text-bg-<%= a.status === 'approved' ? 'success' : a.status === 'rejected' ? 'danger' : 'warning' %>">
                  <%= a.status %>
                </span>
              </td>
              <td class="small text-secondary"><%= new Date(a.created_at).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
<% } %>

<h2 class="h5 mb-3"><i class="bi bi-clock-history"></i> Recent matches</h2>
<% if (recent.length === 0) { %>
  <div class="card tile"><div class="card-body text-center text-secondary py-4">
    <i class="bi bi-inbox fs-1 opacity-50 d-block mb-2"></i>
    No matches yet.
  </div></div>
<% } else { %>
  <div class="row g-3">
    <% recent.forEach(function(m){ %>
      <div class="col-md-6">
        <div class="card tile h-100"><div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <strong><%= m.challenger_name %></strong>
            <span class="text-secondary small">vs</span>
            <strong><%= m.opponent_name %></strong>
            <span class="badge text-bg-<%= statusColor[m.status] || 'secondary' %>"><%= m.status %></span>
          </div>
          <div class="small text-secondary">
            <i class="bi bi-calendar-event"></i> <%= new Date(m.proposed_at).toLocaleString() %>
            <br>
            <i class="bi bi-geo-alt"></i> <%= m.location %>
          </div>
        </div></div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
