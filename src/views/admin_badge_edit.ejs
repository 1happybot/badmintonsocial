<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-pencil-square"></i> Edit Badge</h1>
  <a href="/admin" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left"></i> Back to Admin
  </a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card tile">
      <div class="card-body">
        <form method="post" action="/admin/badges/<%= badge.id %>/edit" class="row g-3">
          <div class="col-12">
            <label class="form-label">Badge name</label>
            <input class="form-control" name="name" required maxlength="80" value="<%= badge.name %>">
          </div>
          <div class="col-12">
            <label class="form-label">Badge slug</label>
            <input class="form-control" name="slug" required maxlength="80" pattern="[a-z0-9-]+" value="<%= badge.slug %>">
          </div>
          <div class="col-12">
            <label class="form-label">Description</label>
            <textarea class="form-control" name="description" rows="3" maxlength="220"><%= badge.description || '' %></textarea>
          </div>
          <div class="col-md-7">
            <label class="form-label">Criteria type</label>
            <select class="form-select" name="criteria_type" required>
              <% criteriaOptions.forEach(function(opt){ %>
                <option value="<%= opt %>" <%= badge.criteria_type === opt ? 'selected' : '' %>><%= opt %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-5">
            <label class="form-label">Threshold</label>
            <input type="number" min="1" class="form-control" name="threshold" value="<%= badge.threshold %>" required>
          </div>
          <div class="col-12 d-flex gap-2">
            <button class="btn btn-primary" type="submit"><i class="bi bi-check-circle"></i> Save changes</button>
            <a href="/admin" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
