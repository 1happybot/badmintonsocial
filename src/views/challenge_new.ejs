<%- include('partials/header') %>

<%
  const ratingColor = opponent.skill_rating >= 8 ? 'warning' : opponent.skill_rating >= 5 ? 'info' : 'success';
  const initial = (opponent.name || '?').trim().charAt(0).toUpperCase();
%>

<div class="row justify-content-center">
  <div class="col-md-8 col-lg-7">
    <div class="card tile mb-3">
      <div class="card-body d-flex align-items-center">
        <div class="avatar avatar-lg bg-primary-subtle text-primary me-3"><%= initial %></div>
        <div>
          <div class="text-secondary small">You're challenging</div>
          <h1 class="h4 mb-1"><%= opponent.name %></h1>
          <div class="small">
            <span class="text-secondary"><i class="bi bi-geo-alt"></i> <%= opponent.city || 'Unknown city' %></span>
            <span class="badge text-bg-<%= ratingColor %> ms-1">Rating <%= opponent.skill_rating %>/10</span>
          </div>
        </div>
      </div>
    </div>

    <div class="card tile">
      <div class="card-body p-4">
        <form method="post" action="/challenges">
          <input type="hidden" name="opponent_id" value="<%= opponent.id %>">

          <div class="mb-3">
            <label class="form-label"><i class="bi bi-calendar-event"></i> When</label>
            <input type="datetime-local" name="proposed_at" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label"><i class="bi bi-geo-alt"></i> Where</label>
            <input type="text" name="location" class="form-control" required placeholder="Court / venue address" maxlength="160">
          </div>
          <div class="mb-4">
            <label class="form-label"><i class="bi bi-chat-text"></i> Message <span class="text-secondary fw-normal">(optional)</span></label>
            <textarea name="message" class="form-control" rows="3" maxlength="400" placeholder="Best of 3, bring own racquet, etc."></textarea>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1">
              <i class="bi bi-send"></i> Send challenge
            </button>
            <a class="btn btn-outline-secondary" href="/players">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
