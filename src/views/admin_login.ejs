<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card tile">
      <div class="card-body p-4 p-md-5">
        <h1 class="h3 text-center mb-1"><i class="bi bi-shield-lock text-primary"></i> Admin Login</h1>
        <p class="text-secondary text-center mb-4">Restricted access for platform administrators</p>

        <form method="post" action="/admin/login">
          <div class="mb-3">
            <label class="form-label">Admin email</label>
            <input type="email" name="email" class="form-control" required maxlength="160" value="<%= form.email || '' %>">
          </div>
          <div class="mb-4">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" required minlength="8">
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-box-arrow-in-right"></i> Login as admin
          </button>
        </form>

        <p class="text-center text-secondary small mt-4 mb-0">
          <a href="/admin/forgot-password">Forgot password?</a>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
