<%- include('partials/header') %>
<div class="text-center py-4">
  <i class="bi bi-exclamation-triangle display-1 text-warning"></i>
  <h1 class="mt-3">Something went wrong</h1>
  <p class="text-secondary">Please try again. If the problem persists, contact the site admin.</p>
  <a class="btn btn-outline-light" href="/"><i class="bi bi-house"></i> Back home</a>
</div>
<% if (error) { %>
  <pre class="bg-body-tertiary border rounded p-3 mt-4 small"><%= error.stack || String(error) %></pre>
<% } %>
<%- include('partials/footer') %>
