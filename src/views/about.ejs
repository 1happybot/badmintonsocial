<%- include('partials/header') %>

<div class="container py-5">
  <!-- Hero Section -->
  <section class="text-center mb-5 pb-5 border-bottom">
    <span class="badge rounded-pill text-bg-primary mb-3 fs-6">
      <i class="bi bi-info-circle"></i> Our Story
    </span>
    <h1 class="display-4 fw-bold mb-4">
      TopMinton Sverige
    </h1>
    <p class="lead text-secondary mx-auto" style="max-width: 600px;">
      Connecting passionate badminton players across Sweden to build a thriving community and elevate the sport.
    </p>
  </section>

  <!-- Mission & Vision -->
  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="card h-100 border-0 bg-body-secondary">
        <div class="card-body">
          <div class="display-5 text-primary mb-3">
            <i class="bi bi-rocket-takeoff"></i>
          </div>
          <h3 class="card-title h4 mb-3">Our Mission</h3>
          <p class="text-secondary mb-0">
            To revolutionize how badminton players in Sweden find opponents, organize matches, and build friendships. 
            We believe every player deserves easy access to challenges, competitive matches, and a supportive community 
            of fellow badminton enthusiasts.
          </p>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card h-100 border-0 bg-body-secondary">
        <div class="card-body">
          <div class="display-5 text-info mb-3">
            <i class="bi bi-eye"></i>
          </div>
          <h3 class="card-title h4 mb-3">Our Vision</h3>
          <p class="text-secondary mb-0">
            A Sweden where every badminton player can instantly find skilled opponents, arrange matches in their city, 
            and track their competitive journey. TopMinton is the trusted platform connecting Sweden's badminton 
            community in one place.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- The Problem We Solve -->
  <section class="mb-5 pb-5 border-bottom">
    <h2 class="h3 fw-bold mb-4">The Problem We Solve</h2>
    <div class="row g-3">
      <div class="col-md-4">
        <div class="card tile h-100 border-0">
          <div class="card-body">
            <div class="h5 text-danger mb-3">
              <i class="bi bi-exclamation-circle"></i> Hard to Find Good Players
            </div>
            <p class="text-secondary small mb-0">
              Swedish badminton players waste hours searching for worthy opponents on forums and social media groups.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card tile h-100 border-0">
          <div class="card-body">
            <div class="h5 text-warning mb-3">
              <i class="bi bi-clock"></i> Organizing is Tedious
            </div>
            <p class="text-secondary small mb-0">
              Setting up matches requires scattered emails, WhatsApp messages, and coordination across multiple channels.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card tile h-100 border-0">
          <div class="card-body">
            <div class="h5 text-info mb-3">
              <i class="bi bi-community"></i> No Unified Community
            </div>
            <p class="text-secondary small mb-0">
              Swedish badminton lacks a central hub where players connect, share experiences, and track achievements.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Solution -->
  <section class="mb-5 pb-5 border-bottom">
    <h2 class="h3 fw-bold mb-4">Our Solution</h2>
    <div class="row g-4">
      <div class="col-md-6">
        <div class="card border-0 h-100">
          <div class="card-body">
            <h5 class="card-title text-primary mb-3">
              <i class="bi bi-search"></i> Smart Player Discovery
            </h5>
            <p class="text-secondary mb-0">
              Browse players in your Swedish city, filter by skill level (1–10 scale), and see their win-loss records. 
              Find the perfect match for your next game.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 h-100">
          <div class="card-body">
            <h5 class="card-title text-info mb-3">
              <i class="bi bi-send"></i> One-Click Challenges
            </h5>
            <p class="text-secondary mb-0">
              Challenge any player with your proposed time, court, and location. Accept or decline incoming challenges 
              with ease.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 h-100">
          <div class="card-body">
            <h5 class="card-title text-success mb-3">
              <i class="bi bi-people-fill"></i> Host Group Matches
            </h5>
            <p class="text-secondary mb-0">
              Create hosted matches for 2–12 players. Set the date, time, and location—let other players join and play 
              together.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 h-100">
          <div class="card-body">
            <h5 class="card-title text-warning mb-3">
              <i class="bi bi-graph-up"></i> Track Your Progress
            </h5>
            <p class="text-secondary mb-0">
              Log match results, build your win-loss record, and see your skill rating recognized by the community.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Sweden -->
  <section class="mb-5 pb-5 border-bottom">
    <h2 class="h3 fw-bold mb-4">Why TopMinton is Built for Sweden</h2>
    <div class="card bg-body-secondary border-0">
      <div class="card-body p-4">
        <ul class="list-unstyled">
          <li class="mb-3">
            <strong class="text-primary"><i class="bi bi-geo-alt"></i> Local Focus</strong>
            <p class="text-secondary mb-0">
              We operate exclusively in Sweden, with deep understanding of Swedish badminton culture and player preferences.
            </p>
          </li>
          <li class="mb-3">
            <strong class="text-info"><i class="bi bi-translate"></i> Swedish Community</strong>
            <p class="text-secondary mb-0">
              Built by Swedish badminton enthusiasts for Swedish players. Support, updates, and events are tailored to the Swedish community.
            </p>
          </li>
          <li class="mb-3">
            <strong class="text-success"><i class="bi bi-heart"></i> Swedish Values</strong>
            <p class="text-secondary mb-0">
              We champion fair play, sportsmanship, and inclusive community values that resonate with Swedish players.
            </p>
          </li>
          <li>
            <strong class="text-warning"><i class="bi bi-people"></i> Swedish Cities</strong>
            <p class="text-secondary mb-0">
              Find players and matches in Stockholm, Gothenburg, Malmö, and every Swedish city. Connect with players near you.
            </p>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="mb-5">
    <h2 class="h3 fw-bold mb-4">Key Features</h2>
    <div class="row g-3">
      <div class="col-12 col-sm-6 col-lg-3">
        <div class="card tile border-0 text-center">
          <div class="card-body">
            <div class="h3 text-primary mb-2">🏸</div>
            <h5 class="card-title small mb-2">Player Profiles</h5>
            <p class="text-secondary tiny mb-0">Skill ratings, activity history, and preferences</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-3">
        <div class="card tile border-0 text-center">
          <div class="card-body">
            <div class="h3 text-info mb-2">⚔️</div>
            <h5 class="card-title small mb-2">Direct Challenges</h5>
            <p class="text-secondary tiny mb-0">One-on-one match proposals</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-3">
        <div class="card tile border-0 text-center">
          <div class="card-body">
            <div class="h3 text-success mb-2">👥</div>
            <h5 class="card-title small mb-2">Group Matches</h5>
            <p class="text-secondary tiny mb-0">Host games for 2–12 players</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-lg-3">
        <div class="card tile border-0 text-center">
          <div class="card-body">
            <div class="h3 text-warning mb-2">📊</div>
            <h5 class="card-title small mb-2">Stats & Records</h5>
            <p class="text-secondary tiny mb-0">Track matches, badges, and progress</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="text-center">
    <div class="card bg-primary border-0">
      <div class="card-body p-5">
        <h2 class="h3 fw-bold mb-3">Join the Swedish Badminton Community Today</h2>
        <p class="lead text-light mb-4">
          Start playing more. Challenge smarter. Build friendships. All in one platform.
        </p>
        <% if (!currentUser) { %>
          <a class="btn btn-light btn-lg" href="/register">
            <i class="bi bi-person-plus"></i> Create Your Profile
          </a>
        <% } else { %>
          <a class="btn btn-light btn-lg" href="/players">
            <i class="bi bi-people"></i> Browse Players
          </a>
        <% } %>
      </div>
    </div>
  </section>
</div>

<%- include('partials/footer') %>
