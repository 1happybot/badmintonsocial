<%- include('partials/header') %>

<div class="container py-5">
  <section class="text-center mb-5 pb-5 border-bottom">
    <span class="badge rounded-pill text-bg-primary mb-3 fs-6">
      <i class="bi bi-info-circle"></i> About Us
    </span>
    <h1 class="display-5 fw-bold mb-3">Built by badminton friends in Stockholm</h1>
    <p class="lead text-secondary mx-auto" style="max-width: 760px;">
      This app started with a simple frustration: it was hard to find good-level badminton players and reliable sessions.
      We were a group of friends who met through badminton in Stockholm, and we built the tool we wished we had.
    </p>
  </section>

  <section class="mb-5 pb-5 border-bottom">
    <div class="row g-4">
      <div class="col-md-6">
        <div class="card h-100 border-0 bg-body-secondary">
          <div class="card-body">
            <div class="display-6 text-primary mb-2"><i class="bi bi-bullseye"></i></div>
            <h2 class="h4 mb-3">Our mission</h2>
            <p class="text-secondary mb-0">
              Help badminton players quickly find the right opponents and the right sessions for their level.
              Less searching, less guessing, more quality games.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card h-100 border-0 bg-body-secondary">
          <div class="card-body">
            <div class="display-6 text-success mb-2"><i class="bi bi-people"></i></div>
            <h2 class="h4 mb-3">Who this is for</h2>
            <p class="text-secondary mb-0">
              Anyone who wants better games: beginners finding suitable partners, improving players seeking stronger rallies,
              and hosts trying to run balanced sessions.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-5 pb-5 border-bottom">
    <div class="card border-success-subtle bg-body-secondary">
      <div class="card-body p-4 p-md-5">
        <h2 class="h3 mb-3 text-success"><i class="bi bi-shield-check"></i> Our public promise</h2>
        <p class="lead mb-2">
          We will never make money from matching players.
        </p>
        <p class="text-secondary mb-0">
          Matching is the core community value of this platform and it stays free.
          If we introduce paid features in the future, they will be around optional extras, not who gets matched with whom.
        </p>
      </div>
    </div>
  </section>

  <section class="mb-5 pb-5 border-bottom">
    <h2 class="h3 fw-bold mb-4">What we are solving</h2>
    <div class="row g-3">
      <div class="col-md-4">
        <div class="card tile h-100 border-0">
          <div class="card-body">
            <h3 class="h5 mb-2 text-danger"><i class="bi bi-search"></i> Skill mismatch</h3>
            <p class="small text-secondary mb-0">
              Players often spend weeks finding someone at a similar level.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card tile h-100 border-0">
          <div class="card-body">
            <h3 class="h5 mb-2 text-warning"><i class="bi bi-calendar-event"></i> Session uncertainty</h3>
            <p class="small text-secondary mb-0">
              It is hard to know if a session is full, serious, social, or right for your pace.
            </p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card tile h-100 border-0">
          <div class="card-body">
            <h3 class="h5 mb-2 text-info"><i class="bi bi-chat-dots"></i> Too much coordination overhead</h3>
            <p class="small text-secondary mb-0">
              Players juggle multiple chats and groups instead of spending time on court.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-5">
    <h2 class="h3 fw-bold mb-4">How this app helps</h2>
    <div class="row g-3">
      <div class="col-md-6 col-lg-3">
        <div class="card border-0 h-100">
          <div class="card-body">
            <h3 class="h6 text-primary mb-2"><i class="bi bi-person-lines-fill"></i> Find good-level players</h3>
            <p class="small text-secondary mb-0">Discover players with profiles and level signals that actually help with fit.</p>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="card border-0 h-100">
          <div class="card-body">
            <h3 class="h6 text-info mb-2"><i class="bi bi-lightning"></i> Challenge quickly</h3>
            <p class="small text-secondary mb-0">Send direct challenges with clear time and location details in one flow.</p>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="card border-0 h-100">
          <div class="card-body">
            <h3 class="h6 text-success mb-2"><i class="bi bi-people-fill"></i> Join hosted sessions</h3>
            <p class="small text-secondary mb-0">See who is hosting, what level to expect, and join sessions that fit your game.</p>
          </div>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="card border-0 h-100">
          <div class="card-body">
            <h3 class="h6 text-warning mb-2"><i class="bi bi-check2-circle"></i> Build trust over time</h3>
            <p class="small text-secondary mb-0">Reliable participation and post-match updates make future matching better for everyone.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="text-center">
    <div class="card bg-primary border-0">
      <div class="card-body p-5">
        <h2 class="h3 fw-bold mb-3">Find your next quality game</h2>
        <p class="lead text-light mb-4">
          Better player matching. Better sessions. More time actually playing badminton.
        </p>
        <% if (!currentUser) { %>
          <a class="btn btn-light btn-lg" href="/register"><i class="bi bi-person-plus"></i> Create Your Profile</a>
        <% } else { %>
          <a class="btn btn-light btn-lg" href="/challenges"><i class="bi bi-trophy"></i> Go to Challenges</a>
        <% } %>
      </div>
    </div>
  </section>
</div>

<%- include('partials/footer') %>
