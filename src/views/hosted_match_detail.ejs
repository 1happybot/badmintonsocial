<%- include('partials/header') %>

<%
  function fmtDate(d) { return new Date(d).toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' }); }
  function fmtTime(d) { return new Date(d).toLocaleString(undefined, { dateStyle: 'short', timeStyle: 'short' }); }
  function fmtDay(d) { return new Date(d).toLocaleString(undefined, { weekday: 'long', day: 'numeric' }); }
  function fmtMonth(d) { return new Date(d).toLocaleString(undefined, { month: 'short', year: '2-digit' }); }
  function fmtStartTime(d) { return new Date(d).toLocaleString(undefined, { timeStyle: 'short' }); }
  function getSpotColor(pct) {
    if (pct >= 100) return '#ffc107';      // Full - warning
    if (pct >= 75) return '#28a745';       // Almost full - success
    return '#17a2b8';                      // Plenty of spots - info
  }
  const spotsPercentage = (participants.length / match.max_players) * 100;
%>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/hosted-matches">Hosted sessions</a></li>
    <li class="breadcrumb-item active" aria-current="page"><%= match.title %></li>
  </ol>
</nav>

<!-- MEETUP-STYLE HERO SECTION -->
<section class="event-hero card tile mb-4 overflow-hidden" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); position: relative;">
  <div class="card-body position-relative">
    <div class="row align-items-center g-4">
      <!-- Main Content -->
      <div class="col-lg-8">
        <div class="mb-2">
          <span class="badge rounded-pill text-bg-light text-dark">
            <i class="bi bi-calendar-event"></i> Badminton session
          </span>
          <span class="badge rounded-pill text-bg-<%= match.status === 'open' ? 'success' : match.status === 'full' ? 'warning' : match.status === 'completed' ? 'primary' : 'secondary' %> ms-2">
            <%= match.status.charAt(0).toUpperCase() + match.status.slice(1) %>
          </span>
        </div>
        <h1 class="display-5 text-white mb-3" style="font-weight: 700;"><%= match.title %></h1>
        
        <!-- Key Info -->
        <div class="row text-white small mb-2">
          <div class="col-auto d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-calendar3"></i>
            <span><strong><%= fmtDay(match.scheduled_at) %></strong> · <%= fmtMonth(match.scheduled_at) %></span>
          </div>
          <div class="col-auto d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-clock"></i>
            <span><strong><%= fmtStartTime(match.scheduled_at) %></strong></span>
          </div>
          <div class="col-auto d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-geo-alt"></i>
            <span><%= match.location %></span>
          </div>
        </div>

        <!-- Host Info -->
        <div class="text-white-50 small">
          <i class="bi bi-person"></i> Hosted by <strong class="text-white"><%= match.host_name %></strong>
          <% if (match.host_city) { %><span class="mx-1">·</span><i class="bi bi-geo"></i> <%= match.host_city %><% } %>
        </div>
      </div>

      <!-- DATE CARD (Right side) -->
      <div class="col-lg-4 d-flex justify-content-end">
        <div class="text-center text-white p-4" style="background: rgba(255,255,255,0.15); border-radius: 12px; backdrop-filter: blur(10px); min-width: 140px;">
          <div style="font-size: 0.875rem; opacity: 0.9; margin-bottom: 0.5rem;">
            <i class="bi bi-calendar"></i> <%= new Date(match.scheduled_at).toLocaleDateString('sv-SE', { month: 'short' }).toUpperCase() %>
          </div>
          <div style="font-size: 2.5rem; font-weight: 700; line-height: 1;">
            <%= new Date(match.scheduled_at).getDate() %>
          </div>
          <div style="font-size: 0.875rem; opacity: 0.9; margin-top: 0.5rem;">
            <i class="bi bi-clock"></i> <%= fmtStartTime(match.scheduled_at) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="row g-4 align-items-start">
  <div class="col-lg-8">
    <!-- EVENT DETAILS CARDS (Grid Layout) -->
    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <div class="card tile h-100">
          <div class="card-body">
            <div class="d-flex align-items-center gap-2 mb-2">
              <i class="bi bi-calendar-check text-primary" style="font-size: 1.5rem;"></i>
              <span class="text-secondary small text-uppercase fw-bold">When</span>
            </div>
            <div class="h5 mb-0"><%= new Date(match.scheduled_at).toLocaleDateString('sv-SE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></div>
            <div class="text-secondary small mt-1"><%= fmtStartTime(match.scheduled_at) %></div>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card tile h-100">
          <div class="card-body">
            <div class="d-flex align-items-center gap-2 mb-2">
              <i class="bi bi-geo-alt text-primary" style="font-size: 1.5rem;"></i>
              <span class="text-secondary small text-uppercase fw-bold">Where</span>
            </div>
            <div class="h5 mb-0"><%= match.location %></div>
            <div class="text-secondary small mt-1">📍 Central Stockholm</div>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card tile h-100">
          <div class="card-body">
            <div class="d-flex align-items-center gap-2 mb-2">
              <i class="bi bi-bullseye text-primary" style="font-size: 1.5rem;"></i>
              <span class="text-secondary small text-uppercase fw-bold">Level</span>
            </div>
            <div class="h5 mb-0"><%= match.match_level || 5 %>/10 - <%= match.match_level >= 8 ? 'Advanced' : match.match_level >= 6 ? 'Intermediate' : 'Beginner' %></div>
            <div class="text-secondary small mt-1">All skill levels welcome</div>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card tile h-100">
          <div class="card-body">
            <div class="d-flex align-items-center gap-2 mb-2">
              <i class="bi bi-feather text-primary" style="font-size: 1.5rem;"></i>
              <span class="text-secondary small text-uppercase fw-bold">Shuttles</span>
            </div>
            <div class="h5 mb-0"><%= match.shuttle_type === 'plastics' ? 'Plastics' : 'Feathers' %></div>
            <div class="text-secondary small mt-1"><%= match.shuttle_type === 'plastics' ? 'Durable practice shuttles' : 'Premium feathered shuttles' %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- HOST MESSAGE -->
    <% if (match.message) { %>
      <div class="card tile mb-4" style="border-left: 4px solid #667eea;">
        <div class="card-body">
          <div class="small text-secondary text-uppercase fw-bold mb-2"><i class="bi bi-chat-quote"></i> Host message</div>
          <p class="mb-0 fst-italic" style="font-size: 1.05rem;"><%= match.message %></p>
        </div>
      </div>
    <% } %>

    <!-- PARTICIPANTS SECTION (Grid Display) -->
    <div class="card tile mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
          <h2 class="h5 mb-0"><i class="bi bi-people-fill text-primary"></i> Players joined</h2>
          <span class="badge text-bg-primary"><%= participants.length %>/<%= match.max_players %></span>
        </div>
        
        <% if (participants.length === 0) { %>
          <div class="text-center py-4 text-secondary">
            <i class="bi bi-people" style="font-size: 2rem; opacity: 0.3;"></i>
            <p class="mt-2 mb-0">Be the first to join!</p>
          </div>
        <% } else { %>
          <div class="d-grid gap-3">
            <% participants.slice(0, 8).forEach(function(p, idx){ %>
              <div class="d-flex align-items-center gap-2 pb-2 <%= idx < participants.length - 1 ? 'border-bottom' : '' %>">
                <span class="avatar avatar-md <%= getAvatarClass(p.id) %>"><%= getAvatarEmoji(p.id) %></span>
                <div class="flex-grow-1">
                  <a href="/players/<%= p.id %>" class="text-decoration-none fw-bold"><%= p.name %></a>
                  <% if (p.id === match.host_id) { %>
                    <span class="badge text-bg-primary ms-1">Host</span>
                  <% } else if (match.status === 'completed') { %>
                    <span class="badge text-bg-<%= p.attendance_status === 'attended' ? 'success' : p.attendance_status === 'no_show' ? 'danger' : 'secondary' %> ms-1">
                      <%= p.attendance_status === 'attended' ? '✓ Attended' : p.attendance_status === 'no_show' ? '✗ No-show' : 'Pending' %>
                    </span>
                  <% } %>
                </div>
              </div>
            <% }) %>
            
            <% if (participants.length > 8) { %>
              <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#allParticipantsModal">
                See all <%= participants.length %> players
              </button>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- CHAT SECTION -->
    <div class="card tile" id="chat">
      <div class="card-body d-flex flex-column" style="min-height: 400px;">
        <h2 class="h5 mb-3"><i class="bi bi-chat-dots text-primary"></i> Session chat</h2>

        <% if (!canChat) { %>
          <div class="alert alert-secondary small mb-0 mt-auto">
            <i class="bi bi-lock"></i> Join this match to chat with the host and other players.
          </div>
        <% } else { %>
          <div class="chat-thread mb-3 flex-grow-1" id="chatThread" style="overflow-y: auto;">
            <% if (messages.length === 0) { %>
              <div class="text-secondary small text-center py-4">No messages yet. Say hi! 👋</div>
            <% } else { %>
              <% messages.forEach(function(msg){
                   const mine = currentUser && currentUser.id === msg.user_id;
              %>
                <div class="chat-message <%= mine ? 'chat-message--mine' : '' %> mb-2">
                  <div class="chat-message__meta small text-secondary">
                    <strong><%= mine ? 'You' : msg.user_name %></strong>
                    <span class="ms-1">• <%= fmtTime(msg.created_at) %></span>
                  </div>
                  <div class="chat-message__body bg-<%= mine ? 'primary' : 'light' %> text-<%= mine ? 'white' : 'dark' %> px-3 py-2 rounded" style="margin-top: 4px; word-wrap: break-word;"><%= msg.body %></div>
                </div>
              <% }) %>
            <% } %>
          </div>

          <form method="post" action="/hosted-matches/<%= match.id %>/messages" class="mt-auto">
            <div class="input-group">
              <input type="text"
                     name="body"
                     class="form-control"
                     placeholder="Write a message..."
                     maxlength="1000"
                     required
                     autocomplete="off" />
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-send"></i>
              </button>
            </div>
            <div class="form-text small">💬 Visible to the host and joined players only.</div>
          </form>
        <% } %>
      </div>
    </div>
  </div>

  <!-- SIDEBAR (Host Profile + Actions) -->
  <div class="col-lg-4">
    <!-- CTA BUTTON (Top Priority) -->
    <div class="card tile mb-4 border-primary" style="border-width: 2px;">
      <div class="card-body">
        <% if (isHost && (match.status === 'open' || match.status === 'full')) { %>
          <form method="post" action="/hosted-matches/<%= match.id %>/complete" class="d-inline"
                onsubmit="return confirm('Mark this match as completed? You earn 25 points. Participant points awarded after you mark attendance.');">
            <button type="submit" class="btn btn-success w-100 btn-lg fw-bold">
              <i class="bi bi-check2-circle"></i> Mark completed
            </button>
          </form>
        <% } else if (isHost && match.status === 'completed') { %>
          <a href="/hosted-matches/<%= match.id %>/participants/status" class="btn btn-primary w-100 btn-lg fw-bold">
            <i class="bi bi-list-check"></i> Settle participants
          </a>
        <% } else if (isHost && match.status !== 'cancelled') { %>
          <div class="alert alert-secondary small mb-0">
            <i class="bi bi-info-circle"></i> This match is <%= match.status %>.
          </div>
        <% } else if (isParticipant && !isHost && match.status !== 'completed' && match.status !== 'cancelled') { %>
          <form method="post" action="/hosted-matches/<%= match.id %>/leave" class="d-inline">
            <button type="submit" class="btn btn-outline-secondary w-100 btn-lg">
              <i class="bi bi-box-arrow-left"></i> Leave session
            </button>
          </form>
        <% } else if (!isParticipant && match.status === 'open') { %>
          <form method="post" action="/hosted-matches/<%= match.id %>/join" class="d-inline">
            <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold">
              <i class="bi bi-box-arrow-in-right"></i> Join session
            </button>
          </form>
        <% } %>
      </div>
    </div>

    <!-- EVENT STATS -->
    <div class="card tile mb-4">
      <div class="card-body">
        <h6 class="text-uppercase small text-secondary fw-bold mb-3">📊 Quick stats</h6>
        
        <!-- Spots Available Bar -->
        <div class="mb-3">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="small fw-bold">Spots</span>
            <span class="badge text-bg-<%= match.status === 'open' ? 'success' : match.status === 'full' ? 'warning' : 'secondary' %>">
              <%= Math.max(0, match.max_players - participants.length) %> left
            </span>
          </div>
          <div class="progress" style="height: 8px;">
            <div class="progress-bar bg-<%= spotsPercentage >= 100 ? 'warning' : 'success' %>" 
                 style="width: <%= Math.min(100, spotsPercentage) %>%;"></div>
          </div>
          <div class="text-secondary small mt-1"><%= participants.length %> of <%= match.max_players %> players</div>
        </div>

        <!-- Quick Info -->
        <ul class="list-unstyled small">
          <li class="mb-2"><i class="bi bi-bullseye text-primary"></i> <span class="ms-2">Level <%= match.match_level || 5 %>/10</span></li>
          <li class="mb-2"><i class="bi bi-feather text-primary"></i> <span class="ms-2"><%= match.shuttle_type === 'plastics' ? 'Plastics' : 'Feathers' %></span></li>
          <li><i class="bi bi-shield-check text-primary"></i> <span class="ms-2">Fair-play protected</span></li>
        </ul>
      </div>
    </div>

    <!-- HOST PROFILE CARD -->
    <div class="card tile mb-4">
      <div class="card-body text-center">
        <div class="mb-3">
          <span class="avatar avatar-lg <%= getAvatarClass(match.host_id) %>" style="font-size: 3rem;">
            <%= getAvatarEmoji(match.host_id) %>
          </span>
        </div>
        <a href="/players/<%= match.host_id %>" class="text-decoration-none">
          <h5 class="mb-1"><%= match.host_name %></h5>
        </a>
        <div class="text-secondary small mb-2">
          <% if (match.host_city) { %><i class="bi bi-geo"></i> <%= match.host_city %><br><% } %>
          <i class="bi bi-shield-check"></i> Verified host
        </div>
        <a href="/players/<%= match.host_id %>" class="btn btn-outline-primary btn-sm w-100">
          View profile
        </a>
      </div>
    </div>

    <!-- SHARE & SAVE -->
    <div class="card tile">
      <div class="card-body">
        <h6 class="text-uppercase small text-secondary fw-bold mb-3">Share</h6>
        <div class="d-grid gap-2">
          <button type="button" class="btn btn-outline-secondary btn-sm" 
                  onclick="navigator.share({title: '<%= match.title %>', text: 'Join me for badminton!', url: window.location.href})">
            <i class="bi bi-share"></i> Share event
          </button>
          <button type="button" class="btn btn-outline-secondary btn-sm" 
                  onclick="navigator.clipboard.writeText(window.location.href); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy link', 2000);">
            <i class="bi bi-link-45deg"></i> Copy link
          </button>
          <button type="button" class="btn btn-outline-danger btn-sm" onclick="alert('Report feature coming soon');">
            <i class="bi bi-flag"></i> Report
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ALL PARTICIPANTS MODAL -->
<% if (participants.length > 8) { %>
  <div class="modal fade" id="allParticipantsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-people-fill"></i> All players (<%= participants.length %>)</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="list-group">
            <% participants.forEach(function(p){ %>
              <a href="/players/<%= p.id %>" class="list-group-item list-group-item-action d-flex align-items-center gap-3">
                <span class="avatar avatar-md <%= getAvatarClass(p.id) %>"><%= getAvatarEmoji(p.id) %></span>
                <div class="flex-grow-1">
                  <div class="fw-bold"><%= p.name %></div>
                  <% if (p.id === match.host_id) { %>
                    <span class="badge text-bg-primary">Host</span>
                  <% } %>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } %>



<script>
  // Auto-scroll chat to bottom
  (function () {
    var thread = document.getElementById('chatThread');
    if (thread) { thread.scrollTop = thread.scrollHeight; }
  })();

  // Share functionality fallback
  if (!navigator.share) {
    document.querySelectorAll('[onclick*="navigator.share"]').forEach(btn => {
      btn.disabled = true;
      btn.textContent = '(Share not supported on this device)';
    });
  }
</script>

<%- include('partials/footer') %>
