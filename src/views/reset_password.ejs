<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card tile">
      <div class="card-body p-4 p-md-5">
        <h1 class="h3 text-center mb-1"><i class="bi bi-lock-fill text-primary"></i> Set new password</h1>
        <p class="text-secondary text-center mb-4">Choose a strong new password for your account.</p>

        <% if (typeof errorMessage === 'string' && errorMessage) { %>
          <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= errorMessage %></div>
        <% } %>

        <form method="post" action="/reset-password">
          <input type="hidden" name="token" value="<%= token %>">
          <div class="mb-3">
            <label class="form-label">New password</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input type="password" name="password" class="form-control" required minlength="8" autofocus>
            </div>
            <div class="form-text">At least 8 characters.</div>
          </div>
          <div class="mb-4">
            <label class="form-label">Confirm new password</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
              <input type="password" name="confirm_password" class="form-control" required minlength="8">
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-lg w-100">
            <i class="bi bi-check2-circle"></i> Update password
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
