# TopMinton production environment template
# Copy to .env.production and set strong, real values.

PORT=3000
NODE_ENV=production
DATABASE_URL=postgres://username:password@host:5432/topminton
SESSION_SECRET=replace-with-a-long-random-production-secret

# Optional: bootstrap admin (used if admins table is empty)
ADMIN_EMAIL=admin@topminton.se
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=Platform Admin
